# ============================================================================
# PROJECT NEXUS — Environment Variables Template
# Copy this to .env and fill in real values. NEVER commit .env to git.
# ============================================================================

# --- LLM Providers ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
LLM_PROVIDER=openai                      # openai | anthropic
LLM_MODEL=gpt-4o                         # gpt-4o | claude-sonnet-4-20250514
LLM_TEMPERATURE=0.0                      # 0.0 for deterministic SQL generation
LLM_MAX_TOKENS=4096

# --- PostgreSQL ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=nexus_warehouse
POSTGRES_USER=nexus_admin
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- WhatsApp Business API ---
WHATSAPP_PROVIDER=360dialog              # 360dialog | twilio
WHATSAPP_API_KEY=xxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=xxxxxxxxxxxx
WHATSAPP_VERIFY_TOKEN=nexus_webhook_verify_token
WHATSAPP_WEBHOOK_SECRET=xxxxxxxxxxxx

# --- Application ---
APP_ENV=development                      # development | staging | production
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG
APP_SECRET_KEY=CHANGE_ME_RANDOM_STRING
MAX_UPLOAD_SIZE_MB=50                    # Maximum file size for audit uploads

# --- Streamlit Dashboard ---
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# --- Cost Controls ---
LLM_COST_LIMIT_PER_RUN_USD=2.00         # Max LLM spend per ETL run
LLM_COST_LIMIT_PER_QUERY_USD=0.05       # Max LLM spend per WhatsApp query
LLM_COST_ALERT_THRESHOLD_USD=50.00      # Monthly alert threshold

# --- Data Residency (EU Compliance) ---
DATA_REGION=eu-west-1
ENCRYPTION_AT_REST=true

# --- External API Keys ---
HUNTER_API_KEY=                          # Required for lead enrichment. Get at hunter.io

# --- Observability (optional) ---
SENTRY_DSN=                              # Optional. Leave blank to disable error tracking.
